<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="io.github.anenene3.wanteditemapp.mapper.MessageMapper">

    <insert id="insert" parameterType="io.github.anenene3.wanteditemapp.dto.Message">
        INSERT INTO messages (
            item_id,
            sender_user_id,
            receiver_user_id,
            message_body,
            contact,
            sent_at
        )
        VALUES (
            #{itemId},
            #{senderUserId},
            #{receiverUserId},
            #{messageBody},
            #{contact},
            #{sentAt}
        );
    </insert>

</mapper>
